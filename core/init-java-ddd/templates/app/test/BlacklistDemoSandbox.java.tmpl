// HelmCode Demo slice — safe to delete after onboarding
package {{basePackage}}.servicetest.base;

import {{basePackage}}.facade.blacklist.BlacklistManageFacade;
import {{basePackage}}.facade.blacklist.BlacklistQueryFacade;
import {{basePackage}}.facade.blacklist.model.command.BlacklistAddCommand;
import {{basePackage}}.facade.blacklist.model.command.BlacklistBatchAddCommand;
import {{basePackage}}.facade.blacklist.model.command.BlacklistRemoveCommand;
import {{basePackage}}.facade.blacklist.model.query.BlacklistCheckRequest;
import {{basePackage}}.facade.blacklist.model.query.BlacklistQueryRequest;
import {{basePackage}}.facade.blacklist.model.vo.BlacklistVO;
import com.alibaba.fastjson.JSON;
import com.mycm.common.model.base.Result;
import com.mycm.common.model.paging.Paginator;
import org.springframework.beans.factory.annotation.Autowired;

import java.util.Arrays;

/**
 * Blacklist 手工调试沙箱(对齐 mycmbillmanage 的 PengPengDaWang 风格)。
 *
 * 命名刻意不以 Test.java 结尾,因此默认不会被 surefire 抓到执行;
 * 也不依赖 JUnit/TestNG 注解,只在方法上挂 //@Test 占位,IDE 右键单跑即可。
 *
 * 跑通前提:application-dev.properties 中 zdal 已可连通,且 email_blacklist 表已就绪。
 *
 * 正式的端到端用例请走 src/test/java/{{basePackagePath}}/acts/test/blacklist/
 * 下的 ACTS + TestNG 模板(见 CheckEmailActsTest)——这才是 STANDARD 主推的方式,
 * 本类仅作为联调脚手架。
 */
public class BlacklistDemoSandbox extends AbstractTestBase {

    @Autowired
    private BlacklistManageFacade blacklistManageFacade;

    @Autowired
    private BlacklistQueryFacade blacklistQueryFacade;

    //@Test
    public void testCheckEmail_Success() {
        BlacklistCheckRequest request = new BlacklistCheckRequest();
        request.setEmail("demo-" + System.currentTimeMillis() + "@example.com");
        Result<Boolean> result = blacklistQueryFacade.checkEmail(request);
        System.out.println(JSON.toJSONString(result));
    }

    //@Test
    public void testAddBlacklist_Success() {
        BlacklistAddCommand command = new BlacklistAddCommand();
        command.setEmailAddress("demo-" + System.currentTimeMillis() + "@example.com");
        command.setModifier("demo-sandbox");
        command.setRemark("demo sandbox sample");
        Result<Void> result = blacklistManageFacade.addBlacklist(command);
        System.out.println(JSON.toJSONString(result));
    }

    //@Test
    public void testRemoveBlacklist_Success() {
        BlacklistRemoveCommand command = new BlacklistRemoveCommand();
        command.setId(1L);
        command.setModifier("demo-sandbox");
        Result<Void> result = blacklistManageFacade.removeBlacklist(command);
        System.out.println(JSON.toJSONString(result));
    }

    //@Test
    public void testListByPage_Success() {
        BlacklistQueryRequest request = BlacklistQueryRequest.builder()
                .pageNum(1)
                .pageSize(20)
                .emailAddress("example.com")
                .build();
        Result<Paginator<BlacklistVO>> result = blacklistQueryFacade.listByPage(request);
        System.out.println(JSON.toJSONString(result));
    }

    //@Test
    public void testBatchAdd_Success() {
        BlacklistBatchAddCommand command = new BlacklistBatchAddCommand();
        command.setEmailAddressList(Arrays.asList(
                "demo-batch1-" + System.currentTimeMillis() + "@example.com",
                "demo-batch2-" + System.currentTimeMillis() + "@example.com"
        ));
        command.setModifier("demo-sandbox");
        command.setRemark("demo batch sample");
        Result<Void> result = blacklistManageFacade.batchAddBlacklist(command);
        System.out.println(JSON.toJSONString(result));
    }
}