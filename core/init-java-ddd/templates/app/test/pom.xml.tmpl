<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>{{groupId}}</groupId>
        <artifactId>{{appName}}-parent</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>
    <artifactId>{{appName}}-test</artifactId>
    <version>0.0.1-SNAPSHOT</version>

    <dependencies>
        <dependency>
            <groupId>{{groupId}}</groupId>
            <artifactId>{{appName}}-bootstrap</artifactId>
        </dependency>

        <dependency>
            <groupId>org.springframework.boot</groupId>
            <artifactId>spring-boot-starter-test</artifactId>
            <scope>compile</scope>
            <exclusions>
                <exclusion>
                    <groupId>org.skyscreamer</groupId>
                    <artifactId>jsonassert</artifactId>
                </exclusion>
                <exclusion>
                    <groupId>org.springframework.boot</groupId>
                    <artifactId>spring-boot-starter-logging</artifactId>
                </exclusion>
            </exclusions>
        </dependency>
        <dependency>
            <groupId>com.alipay.test.acts</groupId>
            <artifactId>alipay-sofaboot-acts-common</artifactId>
            <version>2.0.16</version>
            <type>pom</type>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-inline</artifactId>
            <scope>test</scope>
        </dependency>
        <!-- ArchUnit: 把 review-rules §A0 (包内聚) + §I (装配风险) 翻成 mvn test 强制规则。
             由 ArchitectureRulesTest.java 调用,跟 BootContextSmokeTest 同走 strict execution。 -->
        <dependency>
            <groupId>com.tngtech.archunit</groupId>
            <artifactId>archunit-junit5</artifactId>
            <version>1.3.0</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>2.22.2</version>
                <!-- 默认 execution: lenient — 跑 ACTS 集成测试 + 业务 *Test.java。
                     默认挂 isSkipIntegrationTest(本地/CI 默认跳),需要外部资源就绪后才跑。 -->
                <configuration>
                    <skipTests>${isSkipIntegrationTest}</skipTests>
                    <includes>
                        <include>**/*Test.java</include>
                    </includes>
                    <excludes>
                        <!-- strict 测试由独立 execution 处理,这里排除避免重复跑 -->
                        <exclude>**/servicetest/smoke/**</exclude>
                        <exclude>**/servicetest/architecture/**</exclude>
                    </excludes>
                    <testFailureIgnore>true</testFailureIgnore>
                </configuration>
                <executions>
                    <!-- strict execution: ArchitectureRulesTest + BootContextSmokeTest。
                         任何 CI 都必须跑(不挂 isSkipIntegrationTest),失败即挂(不忽略)。
                         拦"包内聚违规 / 接口缺 stub / bean 装配错"等启动期才暴露的问题。
                         详见 review-rules.md §A0 / §I 与 SKILL.md 反模式 #14。 -->
                    <execution>
                        <id>test-arch-and-smoke</id>
                        <phase>test</phase>
                        <goals>
                            <goal>test</goal>
                        </goals>
                        <configuration>
                            <skipTests>false</skipTests>
                            <includes>
                                <include>**/servicetest/smoke/*Test.java</include>
                                <include>**/servicetest/architecture/*Test.java</include>
                            </includes>
                            <excludes combine.self="override"/>
                            <testFailureIgnore>false</testFailureIgnore>
                        </configuration>
                    </execution>
                    <execution>
                        <id>test-testng</id>
                        <phase>test</phase>
                        <goals>
                            <goal>test</goal>
                        </goals>
                        <configuration>
                            <junitArtifactName>none:none</junitArtifactName>
                            <testNGArtifactName>org.testng:testng</testNGArtifactName>
                            <argLine>-Xmx1024m -XX:PermSize=256m -XX:MaxPermSize=512m</argLine>
                            <suiteXmlFiles>
                                <!-- ACTS TestNG suite, 路径与 src/main/resources/actsSuite/ 一致 -->
                                <suiteXmlFile>src/main/resources/actsSuite/{{appName}}-testng-all.xml</suiteXmlFile>
                            </suiteXmlFiles>
                            <forkMode>once</forkMode>
                            <testFailureIgnore>true</testFailureIgnore>
                        </configuration>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>
</project>
