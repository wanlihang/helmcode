<?xml version="1.0" encoding="UTF-8"?>
<Configuration>
    <Properties>
        <Property name="LOG_FILE_PATTERN">
            %d{yyyy-MM-dd HH:mm:ss.SSS} [%X{traceId} %X{rpcId} - %X{loginUserEmail}/%X{loginUserID}/%X{remoteAddr}/%X{clientId} - %X{requestURIWithQueryString}] %-5p %c{2} - %m%n%throwable
        </Property>
    </Properties>
    <Appenders>
        <Console name="STDOUT-APPENDER" target="SYSTEM_OUT">
            <PatternLayout pattern="%d %-5p %c{2} - %m%n%throwable" charset="UTF-8"/>
        </Console>

        <Console name="STDERR-APPENDER" target="SYSTEM_ERR">
            <PatternLayout pattern="%d %-5p %c{2} - %m%n%throwable" charset="UTF-8"/>
        </Console>

        <RollingFile name="ERROR-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/common-error.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/common-error.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
            <ThresholdFilter level="ERROR"/>
        </RollingFile>

        <RollingFile name="APP-DEFAULT-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/app-default.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/app-default.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="DAL-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/dal.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/dal.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="INTEGRATION-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/integration.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/integration.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="MONITOR-LOGGER-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/monitor.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/monitor.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="BIZ-LOGGER-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/biz-service.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/biz-service.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="FACADE-LOGGER-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/facade-service.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/facade-service.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="SCHEDULER-LOGGER-APPENDER" fileName="${ctx:logging.path}/${ctx:spring.application.name}/scheduler.log"
                     filePattern="${ctx:logging.path}/${ctx:spring.application.name}/scheduler.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="SPRING-APPENDER" fileName="${ctx:logging.path}/spring/spring.log"
                     filePattern="${ctx:logging.path}/spring/spring.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>

        <RollingFile name="NO-USAGE-APPENDER" fileName="${ctx:logging.path}/no-usage/no-usage.log"
                     filePattern="${ctx:logging.path}/no-usage/no-usage.log.%d{yyyy-MM-dd}"
                     append="true">
            <PatternLayout pattern="${LOG_FILE_PATTERN}" charset="UTF-8"/>
            <TimeBasedTriggeringPolicy/>
            <DefaultRolloverStrategy/>
        </RollingFile>
    </Appenders>

    <Loggers>
        <AsyncLogger name="STDOUT" additivity="false" level="info">
            <AppenderRef ref="STDOUT-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="STDERR" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="STDERR-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="com.taobao.tair" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="NO-USAGE-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="com.taobao.vipserver" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="NO-USAGE-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="com.taobao.remoting" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="NO-USAGE-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="{{basePackage}}" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="APP-DEFAULT-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
            <AppenderRef ref="STDOUT-APPENDER"/>
        </AsyncLogger>

        <!-- 数据库访问层日志 -->
        <AsyncLogger name="DAL-DETAIL-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="DAL-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <!-- 标准监控日志 -->
        <AsyncLogger name="MONITOR-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="MONITOR-LOGGER-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <!-- 业务服务日志 -->
        <AsyncLogger name="BIZ-SERVICE-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="BIZ-LOGGER-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <!-- Facade 服务日志 (RPC 入口) -->
        <AsyncLogger name="FACADE-SERVICE-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="FACADE-LOGGER-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <!-- 定时任务日志 -->
        <AsyncLogger name="SCHEDULER-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="SCHEDULER-LOGGER-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <!-- 集成 / 外部服务日志 -->
        <AsyncLogger name="SAL-DETAIL-LOGGER" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="INTEGRATION-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncLogger>

        <AsyncLogger name="org.springframework" additivity="false" level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="ERROR-APPENDER"/>
            <AppenderRef ref="SPRING-APPENDER"/>
        </AsyncLogger>

        <AsyncRoot level="${ctx:logging.level.{{basePackage}}}">
            <AppenderRef ref="APP-DEFAULT-APPENDER"/>
            <AppenderRef ref="ERROR-APPENDER"/>
        </AsyncRoot>
    </Loggers>
</Configuration>
