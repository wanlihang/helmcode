package {{basePackage}}.facade.blacklist.model.command;

import com.mycm.common.model.base.BaseRequest;
import lombok.Data;
import lombok.EqualsAndHashCode;

import javax.validation.constraints.Email;
import javax.validation.constraints.NotBlank;
import javax.validation.constraints.Size;
import java.io.Serial;

/**
 * 添加单条黑名单的命令。
 *
 * extends BaseRequest 是 BizTemplate.doProcess(R extends BaseRequest, ...) 的类型约束;
 * 直接 implements Serializable 在编译期就过不去。
 */
@EqualsAndHashCode(callSuper = true)
@Data
public class BlacklistAddCommand extends BaseRequest {

    @Serial
    private static final long serialVersionUID = 1L;

    /** 邮箱地址 */
    @NotBlank(message = "邮箱地址不能为空")
    @Email(message = "邮箱格式不正确")
    private String emailAddress;

    /** 修改人(审计) */
    @NotBlank(message = "修改人不能为空")
    private String modifier;

    /** 备注原因 */
    @Size(max = 256, message = "备注最大 256 字符")
    private String remark;
}
