<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>
    <parent>
        <groupId>{{groupId}}</groupId>
        <artifactId>{{appName}}-parent</artifactId>
        <version>0.0.1-SNAPSHOT</version>
        <relativePath>../../pom.xml</relativePath>
    </parent>
    <artifactId>{{appName}}-facade</artifactId>
    <version>${facade.version}</version>

    <!--
        facade 模块对外发布的契约 jar:只包含 FacadeService 接口 + Request/Response/VO。
        若调用方仍使用 Java 8,可在此覆盖为 <java.version>8</java.version>;默认与主工程一致({{javaVersion}})。
    -->
    <dependencies>
        <!-- SOFA 运行时 API,facade 用 @RpcReference / @RpcProvider 注解时需要 -->
        <dependency>
            <groupId>com.alipay.sofa</groupId>
            <artifactId>runtime-sofa-boot-starter</artifactId>
        </dependency>
        <!-- mycm 公共组件:Result / Paginator / ErrorCodeEnum -->
        <dependency>
            <groupId>com.mycm.common</groupId>
            <artifactId>mycm-common</artifactId>
        </dependency>
        <!-- Lombok 用于 VO / Request / Command 的 @Data -->
        <dependency>
            <groupId>org.projectlombok</groupId>
            <artifactId>lombok</artifactId>
            <scope>provided</scope>
        </dependency>
        <!-- JSR-303 Bean Validation API,用于 @NotBlank / @Valid -->
        <dependency>
            <groupId>javax.validation</groupId>
            <artifactId>validation-api</artifactId>
        </dependency>
        <dependency>
            <groupId>org.springframework</groupId>
            <artifactId>spring-web</artifactId>
        </dependency>
    </dependencies>
</project>
