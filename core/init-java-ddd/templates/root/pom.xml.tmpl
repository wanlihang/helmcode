<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
	xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 https://maven.apache.org/xsd/maven-4.0.0.xsd">
	<modelVersion>4.0.0</modelVersion>
	<parent>
		<groupId>com.alipay.sofa</groupId>
		<artifactId>sofaboot-alipay-dependencies</artifactId>
		<version>{{sofaBootVersion}}</version>
	</parent>
	<groupId>{{groupId}}</groupId>
	<artifactId>{{appName}}-parent</artifactId>
	<version>0.0.1-SNAPSHOT</version>
	<packaging>pom</packaging>
	<name>{{appName}}</name>
	<description>SOFABoot DDD application bootstrapped by HelmCode init-java-ddd</description>

	<modules>
		<module>app/bootstrap</module>
		<module>app/web</module>
		<module>app/application</module>
		<module>app/domain</module>
		<module>app/infrastructure</module>
		<module>app/facade</module>
		<module>app/test</module>
	</modules>

	<properties>
		<java.version>{{javaVersion}}</java.version>
		<facade.version>0.0.1-SNAPSHOT</facade.version>
		<sofa.boot.alipay.version>{{sofaBootVersion}}</sofa.boot.alipay.version>
		<!-- 集成测试默认跳过(对齐 mycmbillmanage):本地/CI 编译期不连真实 DDS,
		     回归测试时本地 mvn -pl app/test test -DisSkipIntegrationTest=false 强制启用 -->
		<isSkipIntegrationTest>true</isSkipIntegrationTest>
		<mycm.common.version>1.0.0.20250828</mycm.common.version>
		<mycm.component.version>1.0.0.20250828</mycm.component.version>
		<mycm.sequence.version>1.0.0.20250828</mycm.sequence.version>
		<mycm.command.version>1.0.0.20250604</mycm.command.version>
		<mapstruct.version>1.6.3</mapstruct.version>
		<lombok.version>1.18.30</lombok.version>
		<lombok-mapstruct-binding.version>0.2.0</lombok-mapstruct-binding.version>
	</properties>

	<dependencyManagement>
		<dependencies>
			<!-- 业务模块 -->
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-bootstrap</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-web</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-application</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-domain</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-infrastructure</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-facade</artifactId>
				<version>${facade.version}</version>
			</dependency>
			<dependency>
				<groupId>{{groupId}}</groupId>
				<artifactId>{{appName}}-test</artifactId>
				<version>0.0.1-SNAPSHOT</version>
			</dependency>
			<dependency>
				<groupId>ch.qos.logback</groupId>
				<artifactId>logback-classic</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>org.slf4j</groupId>
				<artifactId>slf4j-log4j12</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>org.slf4j</groupId>
				<artifactId>slf4j-jdk14</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>org.jboss.slf4j</groupId>
				<artifactId>slf4j-jboss-logging</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>org.slf4j</groupId>
				<artifactId>slf4j-jcl</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>org.apache.logging.log4j</groupId>
				<artifactId>log4j-to-slf4j</artifactId>
				<scope>provided</scope>
			</dependency>
			<dependency>
				<groupId>com.alipay.zdal</groupId>
				<artifactId>zdal-orm-annotation</artifactId>
				<version>1.0.0</version>
			</dependency>
			<!-- mycm 内部公共组件 -->
			<dependency>
				<groupId>com.mycm.common</groupId>
				<artifactId>mycm-common</artifactId>
				<version>${mycm.common.version}</version>
			</dependency>
			<dependency>
				<groupId>com.mycm.common</groupId>
				<artifactId>mycm-component</artifactId>
				<version>${mycm.component.version}</version>
			</dependency>
			<dependency>
				<groupId>com.mycm.common</groupId>
				<artifactId>mycm-sequence</artifactId>
				<version>${mycm.sequence.version}</version>
			</dependency>
			<dependency>
				<groupId>com.mycm.common</groupId>
				<artifactId>mycm-command</artifactId>
				<version>${mycm.command.version}</version>
			</dependency>
			<!-- MapStruct (SOFABoot BOM 未管理,需显式锁版本) -->
			<dependency>
				<groupId>org.mapstruct</groupId>
				<artifactId>mapstruct</artifactId>
				<version>${mapstruct.version}</version>
			</dependency>
			<dependency>
				<groupId>org.mapstruct</groupId>
				<artifactId>mapstruct-processor</artifactId>
				<version>${mapstruct.version}</version>
			</dependency>
			<!-- JSR-303 Bean Validation (SOFABoot BOM 未管理 javax 坐标,显式锁) -->
			<dependency>
				<groupId>javax.validation</groupId>
				<artifactId>validation-api</artifactId>
				<version>2.0.1.Final</version>
			</dependency>
			<!--
			    alipay-common-error 是 mycm-common 的 MycmSysException / MycmBizException
			    祖先类(com.alipay.common.error.ErrorContext)所在 jar。mycm-common 自身
			    并未把这个传递依赖暴露出来,凡是直接 throw new MycmSysException(...)
			    的层(infrastructure / application)都必须显式声明,否则编译期
			    "无法访问 com.alipay.common.error.ErrorContext"。
			-->
			<dependency>
				<groupId>com.alipay.common</groupId>
				<artifactId>alipay-common-error</artifactId>
				<version>1.4</version>
			</dependency>
		</dependencies>
	</dependencyManagement>

	<build>
		<plugins>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-jar-plugin</artifactId>
				<version>2.2</version>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-compiler-plugin</artifactId>
				<version>3.6.1</version>
				<configuration>
					<source>${java.version}</source>
					<target>${java.version}</target>
					<encoding>UTF-8</encoding>
					<compilerArgs>
						<arg>-parameters</arg>
					</compilerArgs>
					<!--
					    annotation processor 显式声明,保证执行顺序:lombok 先生成 getter/setter,
					    mapstruct-processor 再读它们;lombok-mapstruct-binding 把两者桥接起来,
					    缺一不可,缺则 MapStruct 报 "Unknown property" 编译错。
					-->
					<annotationProcessorPaths>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok</artifactId>
							<version>${lombok.version}</version>
						</path>
						<path>
							<groupId>org.mapstruct</groupId>
							<artifactId>mapstruct-processor</artifactId>
							<version>${mapstruct.version}</version>
						</path>
						<path>
							<groupId>org.projectlombok</groupId>
							<artifactId>lombok-mapstruct-binding</artifactId>
							<version>${lombok-mapstruct-binding.version}</version>
						</path>
					</annotationProcessorPaths>
				</configuration>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-surefire-plugin</artifactId>
				<version>2.22.2</version>
				<configuration>
					<threadCount>1</threadCount>
					<includes>
						<include>**/*Tests.java</include>
						<include>**/*Test.java</include>
					</includes>
					<excludes>
						<exclude>**/Abstract*.java</exclude>
					</excludes>
					<argLine>--add-opens=java.base/*=ALL-UNNAMED</argLine>
				</configuration>
				<dependencies>
					<dependency>
						<groupId>org.apache.maven.surefire</groupId>
						<artifactId>surefire-junit-platform</artifactId>
						<version>2.22.2</version>
					</dependency>
				</dependencies>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-source-plugin</artifactId>
				<version>2.0.2</version>
				<executions>
					<execution>
						<id>attach-sources</id>
						<goals>
							<goal>jar</goal>
						</goals>
					</execution>
				</executions>
			</plugin>
			<plugin>
				<groupId>org.apache.maven.plugins</groupId>
				<artifactId>maven-eclipse-plugin</artifactId>
				<version>2.6</version>
				<configuration>
					<downloadSources>true</downloadSources>
				</configuration>
			</plugin>
			<plugin>
				<groupId>com.alipay.sofa.plugins</groupId>
				<artifactId>gitops-maven-plugin</artifactId>
				<version>1.0-SNAPSHOT</version>
			</plugin>
			<plugin>
				<groupId>com.alipay</groupId>
				<artifactId>acts-maven-plugin</artifactId>
				<version>1.0.0</version>
				<configuration>
					<appName>{{appName}}</appName>
					<framework>sofaboot</framework>
				</configuration>
			</plugin>
		</plugins>
	</build>

	<profiles>
		<!-- 蚂蚁主站开发环境 maven 仓库 -->
		<profile>
			<id>dev</id>
			<activation>
				<activeByDefault>true</activeByDefault>
			</activation>
			<repositories>
				<repository>
					<id>alipay_test</id>
					<url>https://maven-test.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</repository>
				<repository>
					<id>alipay_dev</id>
					<url>https://maven-dev.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</repository>
			</repositories>
			<pluginRepositories>
				<pluginRepository>
					<id>alipay_test</id>
					<url>https://maven-test.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</pluginRepository>
				<pluginRepository>
					<id>alipay_dev</id>
					<url>https://maven-dev.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</pluginRepository>
			</pluginRepositories>
		</profile>
		<!-- 蚂蚁主站生产环境 maven 仓库 -->
		<profile>
			<id>prod</id>
			<repositories>
				<repository>
					<id>alipay_test</id>
					<url>https://maven-test.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</repository>
			</repositories>
			<pluginRepositories>
				<pluginRepository>
					<id>alipay_test</id>
					<url>https://maven-test.alipay.com/artifactory/content/groups/public/</url>
					<snapshots>
						<enabled>true</enabled>
					</snapshots>
				</pluginRepository>
			</pluginRepositories>
		</profile>
	</profiles>

</project>
